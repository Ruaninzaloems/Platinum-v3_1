# ============================================================
# Platinum v3.1 — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to git.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL (used by ASSETS-PSQL-API, POS-API, PAYROLL-APP,
#             AFS-UI/api, BUDGET-APP, IDP-UI)
# Local example:  postgresql://postgres:yourpassword@localhost:5432/platinum
# Azure example:  postgresql://adminuser:password@yourserver.postgres.database.azure.com:5432/platinum?sslmode=require
# ----------------------------------------------------------
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/platinum

# ----------------------------------------------------------
# POS-API Session Secret (min 32 random characters)
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------------------------------------
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ----------------------------------------------------------
# SCM-API — SQL Server connection string
# ----------------------------------------------------------
SCM_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=EMS_GeorgeUAT;Persist Security Info=False;User ID=your-user;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# ----------------------------------------------------------
# Payroll JWT Secret
# ----------------------------------------------------------
JWT_SECRET=change-this-to-a-secure-jwt-secret

# ----------------------------------------------------------
# AFS Node API — can use same DATABASE_URL or a separate DB
# ----------------------------------------------------------
AZURE_POSTGRES_URL=postgresql://postgres:yourpassword@localhost:5432/platinum

# ----------------------------------------------------------
# External API keys (only needed for Insight-Performance-Hub)
# ----------------------------------------------------------
OPENAI_API_KEY=
STRIPE_SECRET_KEY=

# ----------------------------------------------------------
# Node environment
# ----------------------------------------------------------
NODE_ENV=development
