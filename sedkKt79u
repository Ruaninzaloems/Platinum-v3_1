entrypoint = "index.js"
modules = ["nodejs-22", "dotnet-10.0", "python-3.11", "postgresql-16"]
hidden = ["package-lock.json"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-24_11"

[deployment]
run = ["node", "index.js"]
deploymentTarget = "autoscale"
ignorePorts = false

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SCM UI"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "POS API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "POS UI"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IDP API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IDP UI"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ASSETS-PSQL-API && dotnet run"
waitForPort = 3000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ASSETS-UI && NG_CLI_ANALYTICS=false npx ng serve --host 0.0.0.0 --port 5000 --proxy-config proxy.conf.json --disable-host-check"
waitForPort = 5000

[[workflows.workflow]]
name = "SCM UI"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd SCM-UI && NG_CLI_ANALYTICS=false npx ng serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json --serve-path /scm-app/"
waitForPort = 4200

[[workflows.workflow]]
name = "POS API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd POS-API && PORT=3003 npx tsx index.ts"
waitForPort = 3003

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "POS UI"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd POS-UI && NG_CLI_ANALYTICS=false npx ng serve --host 0.0.0.0 --port 8080 --proxy-config proxy.conf.json"
waitForPort = 8080

[[workflows.workflow]]
name = "IDP API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd IDP-UI/PlatinumIDP && dotnet run"
waitForPort = 8008

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "IDP UI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd IDP-UI/platinum-idp-client && NG_CLI_ANALYTICS=false npx ng serve --host 0.0.0.0 --port 9000 --proxy-config proxy.conf.json --serve-path /idp-app/"
waitForPort = 9000

[workflows.workflow.metadata]
outputType = "console"

