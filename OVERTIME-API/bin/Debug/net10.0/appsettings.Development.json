{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Database": {
    "Provider": "Postgres"
  },
  "ConnectionStrings": {
    "OvertimeDb": ""
  },
  "Seeding": {
    "SkipOnStartup": true
  },
  "PlatinumIntegration": {
    "UseMock": true,
    "PositionsSource": "Db",
    "EmployeesSource": "Db"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5050"
      }
    }
  }
}
