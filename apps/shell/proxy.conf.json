{
  "/api": {
    "target": "http://localhost:3000",
    "secure": false,
    "changeOrigin": true,
    "timeout": 600000,
    "proxyTimeout": 600000
  },
  "/ASSETS-API": {
    "target": "http://localhost:3001",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/ASSETS-API": "/api" }
  },
  "^/scm-app/api/(.*)$": {
    "target": "http://localhost:3002",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/scm-app/api": "/api" }
  },
  "^/pos-app/api/(.*)$": {
    "target": "http://localhost:3003",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/pos-app/api": "/api" }
  },
  "^/afs-app/api/(.*)$": {
    "target": "http://localhost:9000",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/afs-app/api": "/api" }
  },
  "^/payroll-app/api/(.*)$": {
    "target": "http://localhost:6000",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/payroll-app/api": "/api/v1" }
  },
  "^/idp-app/api/(.*)$": {
    "target": "http://localhost:8008",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/idp-app/api": "/api" }
  },
  "^/budget-app/api/(.*)$": {
    "target": "http://localhost:3001",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/budget-app/api": "/api" }
  },
  "^/insights-app/api/(.*)$": {
    "target": "http://localhost:8080",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/insights-app/api": "/api" }
  },
  "^/overtime-app/api/(.*)$": {
    "target": "http://localhost:8099",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/overtime-app/api": "/api" }
  },
  "/perf-app": {
    "target": "http://localhost:18156",
    "secure": false,
    "changeOrigin": true,
    "ws": true,
    "logLevel": "warn"
  }
}
