entrypoint = "index.js"
modules = ["nodejs-22", "dotnet-10.0", "python-3.11", "postgresql-16"]
hidden = [".config", "package-lock.json"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-24_11"

[deployment]
run = ["node", "index.js"]
deploymentTarget = "autoscale"
ignorePorts = false

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Platinum Shell"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IDP API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Payroll API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SCM API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Budget API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sibling APIs"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ASSETS-PSQL-API && dotnet run"
waitForPort = 3000

[[workflows.workflow]]
name = "Platinum Shell"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/shell && NG_CLI_ANALYTICS=false npx ng serve --host 0.0.0.0 --port 5000 --proxy-config proxy.conf.json"
waitForPort = 5000

[[workflows.workflow]]
name = "IDP API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd IDP-UI/PlatinumIDP && ASPNETCORE_URLS=http://0.0.0.0:8008 dotnet run --no-launch-profile"

[[workflows.workflow]]
name = "Payroll API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd PAYROLL-APP && PORT=6000 node index.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "SCM API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd SCM-API && ASPNETCORE_URLS=http://0.0.0.0:3002 dotnet run --no-launch-profile"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Budget API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd BUDGET-APP/PlatinumBudget.Api && ASPNETCORE_URLS=http://0.0.0.0:3001 dotnet run --no-launch-profile"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Sibling APIs"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node start-apis.js"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 80

[[ports]]
localPort = 4200
externalPort = 4200

[[ports]]
localPort = 4201
externalPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 8081

[[ports]]
localPort = 6000
externalPort = 6000

[[ports]]
localPort = 6800
externalPort = 6800

[[ports]]
localPort = 8008
externalPort = 8008

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8099

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 18156
externalPort = 3003

[userenv]

[userenv.shared]
SKIP_DB_INIT = "true"
AZURE_POSTGRES_URL = "Host=platinum-postgre-sql.postgres.database.azure.com;Port=5432;Database=Assets;Username=Admin_Dev;Password=NOP@ssword_123;SslMode=Require;CommandTimeout=600;Timeout=30"

[userenv.development]
POS_AUTH_DEMO_MODE = "false"
