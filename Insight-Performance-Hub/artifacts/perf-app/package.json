{
  "name": "@workspace/perf-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NG_CLI_ANALYTICS=false ng serve --host=0.0.0.0 --port=${PORT:-18156} --poll=2000",
